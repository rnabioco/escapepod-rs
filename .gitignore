# Generated by Cargo
/target/

# External dependencies
/ext/

# Cargo.lock is recommended to check in for binaries, but this is a workspace
# Uncomment the line below if you want to exclude it
# Cargo.lock

# Editor/IDE
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.DS_Store

# Profiling and debugging
perf.data
perf.data.old
flamegraph.svg
*.profraw
*.profdata

# Test artifacts
*.bak
*.tmp
__pycache__/

# Benchmark temp files (but track scripts)
!/benchmarks/
/benchmarks/*.json
/benchmarks/*.pod5
# ADAPTed CNN weights are CC BY-NC 4.0; export locally via
# scripts/export_adapter_cnn_to_onnx.py, never commit.
/benchmarks/*.onnx
/benchmarks/*.pth
# Flat weight blob derived from the CC BY-NC ONNX (dump_adapter_cnn_weights.py).
/benchmarks/*.weights
/.bench_data/
/.bench_output/
# Demux benchmark/parity scratch (size-tier pod5s, matrix.tsv, mismatch dumps).
/.demux_matrix_out/
/.parity_out*/

# Built documentation
site/

# External data
data/

# notes
notes/
