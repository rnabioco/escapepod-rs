# VHS tape for podfive summary command
Output docs/images/summary.gif

Set Shell "bash"
Set FontFamily "FiraCode Nerd Font Mono"
Set FontSize 16
Set Width 900
Set Height 600
Set LetterSpacing 0
Set LineHeight 1.2
Set Padding 20
Set Theme "Dracula"
Set WindowBar Colorful
Set Margin 20
Set BorderRadius 10

Type "podfive summary ext/pod5-file-format/test_data/multi_fast5_zip_v3.pod5"
Enter
Sleep 3s
